{
  "name": "crypto-radar-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": ">=24.16.0 <25",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "node scripts/dev-with-warmup.mjs",
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
