# Copy this file to .env for local development. These defaults are for the
# local MVP virtual-trading flow: fast backend startup, small scanner universe,
# optional exchange sync workers off, and real order placement disabled.

# Exchange credentials are optional for local virtual trading.
BINANCE_API_KEY=
BINANCE_SECRET=
BYBIT_API_KEY=
BYBIT_SECRET=
BYBIT_HTTP_TIMEOUT_SECONDS=4

# Backend storage and messaging.
DATABASE_URL=postgresql://crypto_radar:crypto_radar@localhost:5432/crypto_radar
REDIS_URL=redis://localhost:6379/0
NATS_URL=nats://localhost:4222
REALTIME_PUBLISH_TIMEOUT_SECONDS=0.75

CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=crypto_radar
CLICKHOUSE_USER=crypto_radar
CLICKHOUSE_PASSWORD=crypto_radar

# Scanner autostart. Keep false for the local MVP so the API can start first;
# start the scanner manually with POST /api/v1/radar/scanner/start.
CRYPTO_RADAR_SCANNER_ENABLED=false

# Local MVP scanner profile. Keep the universe small and warmup bounded.
MAX_SCANNER_PAIRS=20
TRUNCATE_SCANNER_PAIRS_OVER_LIMIT=false
SCANNER_WARMUP_CONCURRENCY=2
SCANNER_WARMUP_TIMEOUT_SECONDS=8
SCANNER_MARKET_DATA_STALE_SECONDS=30

# Historical strategy-test candle backfill. Backtests read ClickHouse first;
# when closed candles are missing for Bybit linear USDT pairs, the worker
# backfills from Bybit and persists candles into market.ohlcv_* tables.
STRATEGY_TEST_HISTORICAL_BACKFILL_ENABLED=true
STRATEGY_TEST_HISTORICAL_BACKFILL_CONCURRENCY=2
STRATEGY_TEST_HISTORICAL_BACKFILL_BATCH_LIMIT=1000
STRATEGY_TEST_HISTORICAL_BACKFILL_MAX_CANDLES_PER_PAIR_TIMEFRAME=500000
STRATEGY_TEST_HISTORICAL_BACKFILL_TIMEOUT_SECONDS=30

# Optional external sync workers. Enable only when you specifically need fresh
# exchange rules, derivative context, or orderbook snapshots in local runs.
EXCHANGE_INSTRUMENT_SYNC_ENABLED=false
EXCHANGE_INSTRUMENT_SYNC_INTERVAL_SECONDS=21600
EXCHANGE_INSTRUMENT_RULES_TTL_SECONDS=86400
BYBIT_INSTRUMENT_RULE_CATEGORIES=linear

DERIVATIVE_SNAPSHOT_SYNC_ENABLED=false
DERIVATIVE_SNAPSHOT_SYNC_INTERVAL_SECONDS=60
DERIVATIVE_SNAPSHOT_TTL_SECONDS=120
BYBIT_DERIVATIVE_SNAPSHOT_CATEGORIES=linear

ORDERBOOK_SNAPSHOT_SYNC_ENABLED=false
ORDERBOOK_SNAPSHOT_SYNC_INTERVAL_SECONDS=10
ORDERBOOK_SNAPSHOT_TTL_SECONDS=15
BYBIT_ORDERBOOK_SNAPSHOT_CATEGORIES=linear
BYBIT_ORDERBOOK_SNAPSHOT_LIMIT=50

# Real account synchronization is disabled in the local virtual profile.
REAL_POSITION_SYNC_ENABLED=false
REAL_POSITION_SYNC_INTERVAL_SECONDS=30
REAL_ORDER_MISSING_EXCHANGE_TIMEOUT_SECONDS=300
EXCHANGE_ACCOUNT_SNAPSHOT_TTL_SECONDS=15

# Real trading safety. Local MVP is virtual/test-only; live order placement
# requires all relevant flags plus an exchange connection that explicitly allows it.
ENABLE_LIVE_TRADING=false
ENABLE_BYBIT_LIVE_ORDER_PLACEMENT=false
ENABLE_BYBIT_MAINNET_ORDER_PLACEMENT=false
REQUIRE_PROTECTIVE_STOP_FOR_LIVE_ENTRY=true

# Observability.
OTEL_SERVICE_NAME=crypto-radar-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_METRICS_ENABLED=true

# Local Grafana defaults.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Frontend API endpoints.
NEXT_PUBLIC_FASTAPI_HTTP_URL=http://127.0.0.1:8000
NEXT_PUBLIC_FASTAPI_WS_URL=ws://127.0.0.1:8000/api/v1/realtime/ws
NEXT_PUBLIC_FASTAPI_SSE_URL=http://127.0.0.1:8000/api/v1/realtime/events
NEXT_PUBLIC_FASTAPI_TIMEOUT_MS=8000

# Sentry and browser telemetry are off by default locally.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAY_ERROR_SAMPLE_RATE=0
NEXT_PUBLIC_WEB_VITALS_ENDPOINT=
