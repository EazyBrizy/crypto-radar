{
  "uid": "crypto-radar-kill-switch",
  "title": "Crypto Radar Kill Switch",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "tags": ["crypto-radar", "execution", "risk"],
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Kill-switch state",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "kill_switch_state", "refId": "A" }],
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Execution rejections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "execution_rejections_count", "refId": "A" }],
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Market data age",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [{ "expr": "stale_data_seconds", "refId": "A" }],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Daily loss and drawdown",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "daily_loss_pct", "refId": "A" },
        { "expr": "drawdown_pct", "refId": "B" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 }
    }
  ]
}
